# PostHog personal API key — used by main.py and posthog_client.py to call the REST API
POSTHOG_API_KEY=phx_your_personal_api_key_here
POSTHOG_PROJECT_ID=12345
# Optional: override if self-hosting PostHog
# POSTHOG_HOST=https://app.posthog.com

# PostHog project API key — the public key used in the JS snippet (starts with phc_)
# Set this to have capture_fixture.py send sessions to PostHog and include replay URLs
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key_here

# GitHub Issues integration (optional)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=owner/repo
